<?xml version="1.0" encoding="utf-8"?>
<!--
    XML 기반 테마 (AndroidManifest에서 android:theme으로 참조)
    실제 앱 테마는 Compose의 TodoTheme이 담당하므로
    여기서는 Activity 초기 배경색 설정 정도만 처리한다.

    Theme.ToDoList: Compose 앱을 위한 최소 테마
    - windowBackground를 흰색으로 설정해 스플래시 화면 깜박임 방지
    - NoActionBar: Compose Scaffold의 TopAppBar를 사용하므로 기본 ActionBar 숨김
-->
<resources>
    <!--
        parent: android 내장 테마 사용
        - Theme.Material3.* 는 com.google.android.material 라이브러리 필요 → 제거
        - 순수 Compose 앱은 XML 테마가 최소화되어도 무방
        - 실제 테마(색상, 타이포그래피)는 Compose 의 TodoTheme 이 담당
    -->
    <style name="Theme.ToDoList" parent="android:Theme.DeviceDefault.NoActionBar">
        <!-- Compose setContent 전에 잠깐 보이는 스플래시 배경색 -->
        <item name="android:windowBackground">@android:color/white</item>
    </style>

    <!--
        잠금화면 위 투명 오버레이 Activity 전용 테마.
        windowIsTranslucent=true : Activity 뒤 배경(잠금화면)이 비침
        backgroundDimEnabled=false : 딤 처리 없음
    -->
    <style name="Theme.LockScreenBanner" parent="android:Theme.DeviceDefault.NoActionBar">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:backgroundDimEnabled">false</item>
        <item name="android:windowNoTitle">true</item>
    </style>
</resources>
