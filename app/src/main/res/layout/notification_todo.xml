<?xml version="1.0" encoding="utf-8"?>
<!-- Compact pill — DecoratedCustomViewStyle 접힌 상태 (max 64dp) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- 상단 흰 배경 (상단 모서리만 둥글게) -->
    <LinearLayout
        android:id="@+id/pill_content"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/bg_notification_pill_top"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="8dp">

        <!-- 우선순위 액센트 바 (색상은 코드에서 setBackgroundColor로 주입) -->
        <ImageView
            android:id="@+id/pill_priority_bar"
            android:layout_width="4dp"
            android:layout_height="36dp"
            android:background="#FFE53935" />

        <!-- 시간 + 제목 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="10dp"
            android:paddingEnd="8dp">

            <TextView
                android:id="@+id/pill_due_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#FF9E9E9E"
                android:text="기한 없음" />

            <TextView
                android:id="@+id/pill_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#FF212121"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="할 일 제목" />
        </LinearLayout>

        <!-- 완료 버튼 -->
        <ImageButton
            android:id="@+id/pill_done_btn"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_done_circle"
            android:background="@android:color/transparent"
            android:contentDescription="완료" />
    </LinearLayout>

    <!-- 하단 네온 그라데이션 띠 (하단 모서리만 둥글게) -->
    <ImageView
        android:id="@+id/pill_neon_strip"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:background="@drawable/bg_notification_neon_strip" />
</LinearLayout>
