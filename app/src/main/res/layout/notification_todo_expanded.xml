<?xml version="1.0" encoding="utf-8"?>
<!--
    잠금화면 / 알림 패널의 커스텀 확장 뷰 (펼쳤을 때 표시)

    [Android 12+ 제약]
    - DecoratedCustomViewStyle 사용 시 시스템 헤더(앱 이름, 시간)가 자동 추가됨
    - 이 뷰 자체의 최대 높이: 256dp
    - RemoteViews에서 사용 가능한 뷰: LinearLayout, RelativeLayout, FrameLayout,
      TextView, ImageView, ImageButton, Button, ProgressBar 등
      (ConstraintLayout, RecyclerView 등 커스텀 뷰는 사용 불가)

    [슬롯 구조]
    slot_0, slot_1, slot_2: 최대 3개의 할 일 슬롯 (고정, VISIBLE/GONE 토글)
    tv_more_count          : "외 N개 더..." 텍스트 (초과 시 표시)
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <!-- ── 슬롯 0 ─────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/slot_0_container"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone">

        <!-- 높은 우선순위 표시 점 (HIGH 일 때만 VISIBLE) -->
        <View
            android:id="@+id/slot_0_priority"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_priority_dot"
            android:visibility="gone" />

        <TextView
            android:id="@+id/slot_0_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:maxLines="1"
            android:ellipsize="end"
            android:textSize="14sp"
            android:textColor="@color/notification_text_primary" />

        <!-- 완료 버튼 -->
        <ImageButton
            android:id="@+id/slot_0_done_btn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_check_circle_outline"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="완료"
            android:tint="@color/notification_action_tint" />
    </LinearLayout>

    <View
        android:id="@+id/divider_0"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/notification_divider"
        android:visibility="gone" />

    <!-- ── 슬롯 1 ─────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/slot_1_container"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone">

        <View
            android:id="@+id/slot_1_priority"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_priority_dot"
            android:visibility="gone" />

        <TextView
            android:id="@+id/slot_1_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:maxLines="1"
            android:ellipsize="end"
            android:textSize="14sp"
            android:textColor="@color/notification_text_primary" />

        <ImageButton
            android:id="@+id/slot_1_done_btn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_check_circle_outline"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="완료"
            android:tint="@color/notification_action_tint" />
    </LinearLayout>

    <View
        android:id="@+id/divider_1"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/notification_divider"
        android:visibility="gone" />

    <!-- ── 슬롯 2 ─────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/slot_2_container"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone">

        <View
            android:id="@+id/slot_2_priority"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_priority_dot"
            android:visibility="gone" />

        <TextView
            android:id="@+id/slot_2_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:maxLines="1"
            android:ellipsize="end"
            android:textSize="14sp"
            android:textColor="@color/notification_text_primary" />

        <ImageButton
            android:id="@+id/slot_2_done_btn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_check_circle_outline"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="완료"
            android:tint="@color/notification_action_tint" />
    </LinearLayout>

    <!-- ── 초과 항목 안내 ───────────────────────────── -->
    <TextView
        android:id="@+id/tv_more_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginTop="4dp"
        android:textSize="12sp"
        android:textColor="@color/notification_text_secondary"
        android:visibility="gone" />

</LinearLayout>
