<?xml version="1.0" encoding="utf-8"?>
<!--
    RemoteViews 전용 알림 확장 뷰

    [RemoteViews 허용 뷰 — Android 공식 문서 기준]
    FrameLayout, LinearLayout, RelativeLayout, GridLayout
    TextView, ImageView, ImageButton, Button, ProgressBar
    Chronometer, TextClock, AnalogClock
    ListView, GridView, StackView, ViewFlipper, AdapterViewFlipper

    [사용 금지 — 인플레이션 크래시 원인]
    - <View>          : android.view.View 는 허용 목록에 없음
                        → 구분선은 height=1dp 짜리 <LinearLayout> 으로 대체
    - android:tint    : RemoteViews XML 에서 미지원
                        → 아이콘 drawable 자체의 색상(ic_check_circle_outline 의 #757575)을 사용
    - ?attr/ / ?android:attr/ 테마 참조 background
                        → 알림 컨텍스트는 앱 테마를 적용하지 않으므로 불가
                        → @android:color/transparent 로 대체

    [슬롯 구조]
    slot_0_container ~ slot_2_container : 최대 3개 할 일 슬롯 (VISIBLE/GONE 토글)
    divider_0 ~ divider_1               : 슬롯 사이 구분선 (LinearLayout 1dp)
    tv_more_count                       : "외 N개 더..." (초과 시 VISIBLE)
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <!-- ══════════════════════════════════════════
         슬롯 0
         ══════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/slot_0_container"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone">

        <!--
            우선순위 점: <View> 대신 <ImageView> 사용
            - src 없이 background 만으로 색상 표현
            - RemoteViews 허용 목록에 ImageView 포함
        -->
        <ImageView
            android:id="@+id/slot_0_priority"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_priority_dot"
            android:visibility="gone" />

        <TextView
            android:id="@+id/slot_0_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:maxLines="1"
            android:ellipsize="end"
            android:textSize="14sp"
            android:textColor="@color/notification_text_primary" />

        <!--
            완료 버튼:
            - android:tint 제거 (RemoteViews 미지원) → drawable 자체 색상(#757575) 사용
            - background: ?attr/ 테마 참조 제거 → @android:color/transparent 사용
        -->
        <ImageButton
            android:id="@+id/slot_0_done_btn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_check_circle_outline"
            android:background="@android:color/transparent"
            android:contentDescription="완료" />
    </LinearLayout>

    <!--
        구분선: <View> 대신 height=1dp 짜리 <LinearLayout> 사용
        - <View>(android.view.View)는 RemoteViews 허용 목록에 없음
        - LinearLayout 은 허용되며 background 속성으로 색상 표현 가능
    -->
    <LinearLayout
        android:id="@+id/divider_0"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:orientation="horizontal"
        android:background="@color/notification_divider"
        android:visibility="gone" />

    <!-- ══════════════════════════════════════════
         슬롯 1
         ══════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/slot_1_container"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone">

        <ImageView
            android:id="@+id/slot_1_priority"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_priority_dot"
            android:visibility="gone" />

        <TextView
            android:id="@+id/slot_1_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:maxLines="1"
            android:ellipsize="end"
            android:textSize="14sp"
            android:textColor="@color/notification_text_primary" />

        <ImageButton
            android:id="@+id/slot_1_done_btn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_check_circle_outline"
            android:background="@android:color/transparent"
            android:contentDescription="완료" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/divider_1"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:orientation="horizontal"
        android:background="@color/notification_divider"
        android:visibility="gone" />

    <!-- ══════════════════════════════════════════
         슬롯 2
         ══════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/slot_2_container"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone">

        <ImageView
            android:id="@+id/slot_2_priority"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_priority_dot"
            android:visibility="gone" />

        <TextView
            android:id="@+id/slot_2_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:maxLines="1"
            android:ellipsize="end"
            android:textSize="14sp"
            android:textColor="@color/notification_text_primary" />

        <ImageButton
            android:id="@+id/slot_2_done_btn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_check_circle_outline"
            android:background="@android:color/transparent"
            android:contentDescription="완료" />
    </LinearLayout>

    <!-- ══════════════════════════════════════════
         초과 항목 안내 ("외 N개 더...")
         ══════════════════════════════════════════ -->
    <TextView
        android:id="@+id/tv_more_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginTop="4dp"
        android:textSize="12sp"
        android:textColor="@color/notification_text_secondary"
        android:visibility="gone" />

</LinearLayout>
