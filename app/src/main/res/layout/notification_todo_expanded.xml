<?xml version="1.0" encoding="utf-8"?>
<!-- 펼친 상태 — 최대 3개 슬롯 (max 256dp) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="4dp">

    <!-- ── Slot 0 ── -->
    <LinearLayout
        android:id="@+id/slot_0_container"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="2dp">

        <ImageView
            android:id="@+id/slot_0_accent"
            android:layout_width="4dp"
            android:layout_height="34dp"
            android:background="#FFE53935" />

        <TextView
            android:id="@+id/slot_0_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingStart="10dp"
            android:paddingEnd="8dp"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#FF212121"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="할 일 제목" />

        <ImageButton
            android:id="@+id/slot_0_done_btn"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_done_circle"
            android:background="@android:color/transparent"
            android:contentDescription="완료" />
    </LinearLayout>

    <!-- ── Slot 1 ── -->
    <LinearLayout
        android:id="@+id/slot_1_container"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="2dp">

        <ImageView
            android:id="@+id/slot_1_accent"
            android:layout_width="4dp"
            android:layout_height="34dp"
            android:background="#FFE53935" />

        <TextView
            android:id="@+id/slot_1_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingStart="10dp"
            android:paddingEnd="8dp"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#FF212121"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="할 일 제목" />

        <ImageButton
            android:id="@+id/slot_1_done_btn"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_done_circle"
            android:background="@android:color/transparent"
            android:contentDescription="완료" />
    </LinearLayout>

    <!-- ── Slot 2 ── -->
    <LinearLayout
        android:id="@+id/slot_2_container"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/slot_2_accent"
            android:layout_width="4dp"
            android:layout_height="34dp"
            android:background="#FFE53935" />

        <TextView
            android:id="@+id/slot_2_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingStart="10dp"
            android:paddingEnd="8dp"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#FF212121"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="할 일 제목" />

        <ImageButton
            android:id="@+id/slot_2_done_btn"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_done_circle"
            android:background="@android:color/transparent"
            android:contentDescription="완료" />
    </LinearLayout>

    <!-- "외 N개 더…" -->
    <TextView
        android:id="@+id/tv_more_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:textSize="11sp"
        android:textColor="#FF9E9E9E"
        android:visibility="gone"
        android:text="외 N개 더…" />
</LinearLayout>
