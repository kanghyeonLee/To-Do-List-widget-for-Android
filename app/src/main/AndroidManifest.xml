<?xml version="1.0" encoding="utf-8"?>
<manifest
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ══════════════════════════════════════════════════════
         권한 선언
         ══════════════════════════════════════════════════════ -->

    <!--
        POST_NOTIFICATIONS (Android 13+ / API 33)
        알림을 게시하려면 런타임 권한 요청 필요.
        13 미만 기기에서는 자동 허용 (maxSdkVersion 설정 불필요).
    -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!--
        FOREGROUND_SERVICE (API 28+)
        startForegroundService() 호출에 필수.
    -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />

    <!--
        FOREGROUND_SERVICE_DATA_SYNC (Android 14+ / API 34)
        foregroundServiceType="dataSync" 사용 시 반드시 선언.
        타입을 선언하지 않으면 API 34+에서 SecurityException 발생.
    -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!--
        RECEIVE_BOOT_COMPLETED
        기기 부팅 후 BootReceiver를 통한 서비스 자동 시작에 필요.
    -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!--
        WAKE_LOCK
        잠금화면에서 알림 인터랙션 중 화면이 꺼지지 않도록 유지.
        (선택 사항: Lock Screen Activity 방식 사용 시 필요)
    -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!--
        REQUEST_IGNORE_BATTERY_OPTIMIZATIONS (API 23+)
        Settings.ACTION_REQUEST_IGNORE_BATTERY_OPTIMIZATIONS 인텐트 사용 시 필수.
        없으면 런타임에 SecurityException 발생.
        [Google Play 정책] 배포 시 배터리 최적화가 핵심 기능에 반드시 필요한 이유를
        Play Console에 선언(declaration)으로 제출해야 함.
    -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!--
        SCHEDULE_EXACT_ALARM (Android 12 / API 31+)
        AlarmManager.setExactAndAllowWhileIdle() 사용 시 필요.
        사용자가 설정에서 개별 앱에 허용해야 함 (런타임 권한 아님).
    -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />

    <!--
        USE_EXACT_ALARM (Android 13 / API 33+)
        캘린더·알람 앱 용도. SCHEDULE_EXACT_ALARM 대신 또는 병행 선언.
        스토어 정책: 알림·리마인더 기능이 핵심 기능인 앱에 한해 허용.
    -->
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />

    <!-- ══════════════════════════════════════════════════════
         Application
         ══════════════════════════════════════════════════════ -->

    <application
        android:name=".TodoApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/ic_todo_notification"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.DeviceDefault.NoActionBar"
        tools:targetApi="31">

        <!-- ── 메인 액티비티 ──────────────────────────────── -->
        <activity
            android:name=".presentation.MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ── Foreground Service ────────────────────────────── -->
        <service
            android:name=".service.TodoForegroundService"
            android:exported="false"
            android:foregroundServiceType="dataSync"
            android:stopWithTask="false" />

        <!-- ── BootReceiver ───────────────────────────────────
             exported="true"   : 시스템 브로드캐스트를 수신하므로 필수
             enabled="true"    : 기본값이지만 명시적으로 선언
        -->
        <receiver
            android:name=".receiver.BootReceiver"
            android:exported="true"
            android:enabled="true">
            <intent-filter>
                <!-- 완전 부팅 완료 -->
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <!--
                    직접 부팅(Direct Boot) 완료 (Android 7.0+ / API 24+)
                    기기가 잠긴 상태에서도 수신 가능.
                    단, directBootAware="true" + Credential Encrypted Storage가 아닌
                    Device Encrypted Storage를 사용해야 함.
                -->
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- ── TaskActionReceiver ─────────────────────────────
             exported="false"  : PendingIntent를 통해서만 수신 (외부 접근 차단)
             알림 버튼(완료/삭제) 클릭 시 이 Receiver가 호출됨.
        -->
        <receiver
            android:name=".receiver.TaskActionReceiver"
            android:exported="false" />

        <!-- ── TodoAlarmReceiver ──────────────────────────────
             AlarmManager가 발화하면 호출됨.
             exported="false" : AlarmManager PendingIntent를 통해서만 수신
        -->
        <receiver
            android:name=".receiver.TodoAlarmReceiver"
            android:exported="false" />

    </application>

</manifest>
